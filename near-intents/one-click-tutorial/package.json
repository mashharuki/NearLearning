{
  "name": "near-intents-one-click-tutorial",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "tokens": "node --import tsx scripts/tokens.ts",
    "quote:dry": "node --import tsx scripts/quote-dry.ts",
    "quote:live": "node --import tsx scripts/quote-live.ts",
    "deposit:near": "node --import tsx scripts/deposit-near.ts",
    "submit": "node --import tsx scripts/submit.ts",
    "status": "node --import tsx scripts/status.ts",
    "walkthrough": "node --import tsx scripts/walkthrough.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "node --import tsx --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "near-api-js": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
