# 1-Click API
# Optional but recommended. Authenticated requests can avoid platform fees and partner rate limits.
ONE_CLICK_API_KEY=
ONE_CLICK_BASE_URL=https://1click.chaindefuser.com

# Tutorial swap defaults.
# The default origin is wNEAR on NEAR. Use `pnpm tokens` to discover valid assetId values.
ORIGIN_ASSET=nep141:wrap.near
DESTINATION_ASSET=nep141:arb-0x912ce59144191c1204e64559fe8253a0e49e6548.omft.near
AMOUNT=0.001
SLIPPAGE_BPS=100
QUOTE_WAITING_TIME_MS=3000

# Addresses used in quote requests.
# For the default destination asset, RECIPIENT must be an Arbitrum-compatible EVM address.
RECIPIENT=0x0000000000000000000000000000000000000000
REFUND_TO=example.near

# Required only for `pnpm deposit:near`.
SENDER_NEAR_ACCOUNT=
SENDER_PRIVATE_KEY=
NEAR_RPC_URL=https://rpc.mainnet.near.org

# Required only before sending real funds.
# NEAR Intents has no testnet. Keep this unset while learning with dry-run scripts.
REAL_SWAP_CONFIRM=
