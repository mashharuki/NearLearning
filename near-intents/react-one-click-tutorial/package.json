{
  "name": "near-intents-react-one-click-tutorial",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"pnpm --filter @near-intents/api dev\" \"pnpm --filter @near-intents/web dev\"",
    "build": "pnpm --filter @near-intents/shared build && pnpm --filter @near-intents/api build && pnpm --filter @near-intents/web build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.1",
    "concurrently": "^9.2.0",
    "playwright": "^1.52.0"
  }
}
